{
  "name": "@laphilosophia/log-scrub",
  "version": "2.0.0",
  "description": "CLI utility to sanitize and beautify JSON logs - redacts sensitive data with syntax highlighting",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "scrub": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --clean",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "npm run build && node smoke.test.mjs"
  },
  "keywords": [
    "log",
    "logs",
    "cli",
    "json",
    "sanitize",
    "redact",
    "security",
    "sensitive-data",
    "stream",
    "beautify",
    "terminal"
  ],
  "author": "Erdem Arslan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laphilosophia/log-scrub.git"
  },
  "bugs": {
    "url": "https://github.com/laphilosophia/log-scrub/issues"
  },
  "homepage": "https://github.com/laphilosophia/log-scrub#readme",
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@laphilosophia/strime": "^3.5.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "json-colorizer": "^3.0.1",
    "split2": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@types/split2": "^4.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
